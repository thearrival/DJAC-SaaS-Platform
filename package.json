{
  "name": "djac_tool",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:strict": "cross-env NODE_ENV=development ALLOW_IN_MEMORY_PERSISTENCE=false tsx watch server/_core/index.ts",
    "dev:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-local.ps1",
    "build": "cross-env NODE_ENV=production vite build && cross-env NODE_ENV=production esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "verify:all": "pnpm lint && pnpm check && pnpm test && pnpm build",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
    "smoke:runtime:strict": "cross-env SMOKE_BASE_URL=http://localhost:3001 SMOKE_EXPECT_MODE=strict node scripts/smoke-runtime.mjs",
    "smoke:scale": "node scripts/load-smoke.mjs",
    "prod:preflight": "node scripts/production-preflight.mjs",
    "prod:preflight:strict": "node scripts/production-preflight.mjs --fail-on-warn --require-billing",
    "prod:preflight:json": "node scripts/production-preflight.mjs --json",
    "db:doctor": "node scripts/db-doctor.mjs",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate": "drizzle-kit migrate",
      "seed:data": "node -e \"console.log('Seed data scripts not yet implemented. Use scripts/compliance-reference-data.mjs for reference data or supabase/seed.sql for DB seeding.')\"",
      "seed:compliance": "node scripts/seed-compliance.mjs",
      "seed:relationships": "node -e \"console.log('Reseed relationships script not yet implemented.')\"",
      "seed:all": "node -e \"console.log('Seed all not yet implemented. Use supabase/seed.sql for DB seeding.')\"",
      "db:seed": "node scripts/seed-compliance.mjs",
    "create-admin": "node scripts/create-admin.mjs",
    "yalla-admin:link": "node scripts/generate-yalla-admin-link.mjs"
  },
