// â”€â”€ Projection â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function project(lon: number, lat: number) {
    return {
        x: ((lon - VB.lonMin) / (VB.lonMax - VB.lonMin)) * VB.w,
        y: ((VB.latMax - lat) / (VB.latMax - VB.latMin)) * VB.h,
    };
}
function pts2path(pts: [number, number][]): string {
    return pts.map(([lon, lat], i) => {
        const p = project(lon, lat);
        return (i === 0 ? "M" : "L") + p.x.toFixed(1) + "," + p.y.toFixed(1);
    }).join(" ") + " Z";
}

