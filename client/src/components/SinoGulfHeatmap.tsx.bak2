// â”€â”€ Color map â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
type Framework = "all" | "PIPL" | "PDPL" | "CSL" | "DSL";

function pipeColor(status: PipeStatus, isDark: boolean): string {
    switch (status) {
        case "compliant": return isDark ? "#01FF7F" : "#16a34a";
        case "approval_required": return isDark ? "#FFD600" : "#d97706";
        case "blocked": return isDark ? "#FF1744" : "#dc2626";
        case "simulated_violation": return isDark ? "#FF6B2B" : "#ea580c";
    }
}

function statusLabel(status: PipeStatus): string {
    switch (status) {
        case "compliant": return "Compliant";
        case "approval_required": return "CAC Approval Required";
        case "blocked": return "Data Transfer Blocked";
        case "simulated_violation": return "Violation Simulated";
    }
}

function statusIcon(status: PipeStatus) {
    switch (status) {
        case "compliant": return <CheckCircle2 className="h-3 w-3" />;
        case "approval_required": return <Clock className="h-3 w-3" />;
        case "blocked": return <X className="h-3 w-3" />;
        case "simulated_violation": return <AlertTriangle className="h-3 w-3" />;
    }
}

// â”€â”€ SVG Path helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function cubicBez(from: { x: number; y: number }, to: { x: number; y: number }): string {
    const dx = (to.x - from.x) * 0.45;
    const dy = (to.y - from.y) * 0.1;
    return `M${from.x},${from.y} C${from.x + dx},${from.y + dy} ${to.x - dx},${to.y - dy} ${to.x},${to.y}`;
}

// â”€â”€ Node compliance score helpers â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
type ActivePipe = Pipe & { activeStatus: PipeStatus };
function calcScore(key: NodeKey, pipes: ActivePipe[]): number {
    const connected = pipes.filter(p => p.from === key || p.to === key);
    if (!connected.length) return 100;
    const scoreMap: Record<PipeStatus, number> = {
        compliant: 100, approval_required: 62, blocked: 18, simulated_violation: 14,
    };
    return Math.round(connected.reduce((s, p) => s + scoreMap[p.activeStatus], 0) / connected.length);
}
function scoreColor(score: number, isDark: boolean) {
    if (score >= 80) return isDark ? "#01FF7F" : "#16a34a";
    if (score >= 50) return isDark ? "#FFD600" : "#d97706";
    return isDark ? "#FF1744" : "#dc2626";
}
// SVG arc path for a score ring (0-100% of circle, starting from top)
function scoreArc(cx: number, cy: number, r: number, score: number): string {
    if (score >= 100) return `M ${cx} ${cy - r} A ${r} ${r} 0 1 1 ${cx + 0.001} ${cy - r}`;
    const endRad = ((score / 100) * 360 - 90) * (Math.PI / 180);
    const x2 = cx + r * Math.cos(endRad);
    const y2 = cy + r * Math.sin(endRad);
    return `M ${cx} ${cy - r} A ${r} ${r} 0 ${score > 50 ? 1 : 0} 1 ${x2} ${y2}`;
}

// â”€â”€ Compass Rose â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function CompassRose({ cx, cy, s, color }: { cx: number; cy: number; s: number; color: string }) {
    return (
        <g opacity={0.42}>
            <polygon points={`${cx},${cy - s} ${cx - s * 0.28},${cy - s * 0.28} ${cx + s * 0.28},${cy - s * 0.28}`} fill={color} />
            <polygon points={`${cx},${cy + s} ${cx - s * 0.28},${cy + s * 0.28} ${cx + s * 0.28},${cy + s * 0.28}`} fill={color} opacity={0.38} />
            <polygon points={`${cx + s},${cy} ${cx + s * 0.28},${cy - s * 0.28} ${cx + s * 0.28},${cy + s * 0.28}`} fill={color} opacity={0.38} />
            <polygon points={`${cx - s},${cy} ${cx - s * 0.28},${cy - s * 0.28} ${cx - s * 0.28},${cy + s * 0.28}`} fill={color} opacity={0.38} />
            <circle cx={cx} cy={cy} r={s * 0.65} fill="none" stroke={color} strokeWidth={0.5} />
            <circle cx={cx} cy={cy} r={s * 0.13} fill={color} />
            <text x={cx} y={cy - s - 4} fill={color} fontSize="7.5" fontWeight="800" textAnchor="middle">N</text>
        </g>
    );
}


// ── Main Component ────────────────────────────────────────────────────────────
export function SinoGulfHeatmap() {
    const { theme } = useTheme();
    const { t } = useLocale();
    const isDark = theme === "dark";

    const [whatIfMode, setWhatIfMode] = useState(false);
    const [hoveredPipe, setHoveredPipe] = useState<string | null>(null);
    const [selectedPipe, setSelectedPipe] = useState<string | null>(null);
    const [filterFw, setFilterFw] = useState<Framework>("all");
    const [tooltip, setTooltip] = useState<{ clientX: number; clientY: number; pipe: ActivePipe } | null>(null);
    const containerRef = useRef<HTMLDivElement>(null);

    const C = useMemo(() => ({
        bg: isDark ? "#030d24" : "#e8f0fc",
        land: isDark ? "#0d1e3e" : "#d4e2f4",
        landBright: isDark ? "#102249" : "#c8d8f0",
        landEdge: isDark ? "#1a3068" : "#93b5e1",
        water: isDark ? "#071230" : "#bdd4ee",
        grid: isDark ? "#0c1c38" : "#cddaee",
        text: isDark ? "#E0E6FF" : "#1e293b",
        muted: isDark ? "#6B7FC4" : "#5c6b8a",
        cyan: isDark ? "#00F7FF" : "#0284c7",
        seaLabel: isDark ? "#3a5080" : "#7090b8",
    }), [isDark]);

    const activePipes = useMemo<ActivePipe[]>(() =>
        PIPES.map(p => ({ ...p, activeStatus: whatIfMode && p.whatIfStatus ? p.whatIfStatus : p.status })),
        [whatIfMode]);

    const filteredPipes = useMemo(() =>
        filterFw === "all" ? activePipes : activePipes.filter(p => p.frameworks.includes(filterFw)),
        [activePipes, filterFw]);

    const counts = useMemo(() => {
        const c = { compliant: 0, approval_required: 0, blocked: 0, simulated_violation: 0 };
        for (const p of activePipes) c[p.activeStatus]++;
        return c;
    }, [activePipes]);

    const handlePipeMouse = useCallback((e: React.MouseEvent, pipe: ActivePipe | null) => {
        if (pipe) { setHoveredPipe(pipe.id); setTooltip({ clientX: e.clientX, clientY: e.clientY, pipe }); }
        else { setHoveredPipe(null); setTooltip(null); }
    }, []);

    const handlePipeClick = useCallback((e: React.MouseEvent, pipe: ActivePipe) => {
        e.stopPropagation();
        setSelectedPipe(prev => prev === pipe.id ? null : pipe.id);
        setTooltip(null);
    }, []);

    const FW_PILLS: Framework[] = ["all", "PIPL", "PDPL", "CSL", "DSL"];

    return (
        <div style={{
            background: "var(--djac-card)", border: "1px solid var(--djac-border)",
            borderRadius: 16, overflow: "hidden",
            boxShadow: isDark ? `0 0 32px ${C.cyan}08` : "none",
        }}>

            {/* ── Header ── */}
            <div style={{ padding: "14px 18px 12px", borderBottom: "1px solid var(--djac-border)", display: "flex", alignItems: "flex-start", justifyContent: "space-between", flexWrap: "wrap", gap: 10 }}>
                <div>
                    <p style={{ color: "var(--djac-muted)", fontSize: 9.5, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: 4 }}>
                        {t("heatmap.sinoGulf.sectionLabel", "Global Regulatory Heatmap")}
                    </p>
                    <h2 style={{ color: "var(--djac-text)", fontSize: 14, fontWeight: 800, margin: 0 }}>
                        {t("heatmap.sinoGulf.title", "Sino-Gulf Data Residency Architecture")}
                    </h2>
                </div>
                <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap" }}>
                    {/* Framework filter pills */}
                    <div style={{ display: "flex", alignItems: "center", gap: 3 }}>
                        <Filter style={{ width: 11, height: 11, color: "var(--djac-muted)" }} />
                        {FW_PILLS.map(fw => (
                            <button key={fw} type="button" onClick={() => setFilterFw(fw)} style={{
                                fontSize: 9.5, fontWeight: 700, padding: "2px 8px", borderRadius: 6,
                                border: `1px solid ${filterFw === fw ? C.cyan : "var(--djac-border)"}`,
                                background: filterFw === fw ? `${C.cyan}18` : "transparent",
                                color: filterFw === fw ? C.cyan : "var(--djac-muted)",
                                cursor: "pointer", transition: "all 0.18s",
                            }}>{fw === "all" ? "All" : fw}</button>
                        ))}
                    </div>
                    {/* Status legend */}
                    {([
                        ["compliant", "Compliant"],
                        ["approval_required", "Approval"],
                        ["blocked", "Blocked"],
                        ...(whatIfMode ? [["simulated_violation" as PipeStatus, "⚡ Simulated"]] : []),
                    ] as [PipeStatus, string][]).map(([status, lbl]) => (
                        <span key={status} style={{
                            display: "inline-flex", alignItems: "center", gap: 4, fontSize: 9.5, fontWeight: 600,
                            color: pipeColor(status, isDark), padding: "2px 7px",
                            border: `1px solid ${pipeColor(status, isDark)}35`, borderRadius: 99,
                            background: `${pipeColor(status, isDark)}10`,
                        }}>
                            <span style={{ width: 5, height: 5, borderRadius: "50%", background: pipeColor(status, isDark), display: "inline-block" }} />
                            {lbl} ({counts[status]})
                        </span>
                    ))}
                    <Button
                        size="sm" variant={whatIfMode ? "destructive" : "outline"}
                        onClick={() => { setWhatIfMode(v => !v); setSelectedPipe(null); setTooltip(null); }}
                        style={{ height: 26, fontSize: 10.5, fontWeight: 700, gap: 4 }}
                    >
                        <FlaskConical className="h-3 w-3" />
                        {whatIfMode ? t("heatmap.sinoGulf.exitSimulation", "Exit Sim") : t("heatmap.sinoGulf.whatIf", "What-If: 1M+ Records")}
                    </Button>
                </div>
            </div>

            {/* ── What-If Banner ── */}
            {whatIfMode && (
                <div style={{ background: isDark ? "rgba(255,107,43,0.10)" : "rgba(234,88,12,0.07)", borderBottom: "1px solid rgba(255,107,43,0.28)", padding: "8px 18px", display: "flex", alignItems: "center", gap: 8 }}>
                    <Zap style={{ color: "#FF6B2B", width: 13, height: 13, flexShrink: 0 }} />
                    <p style={{ color: isDark ? "#FF9B6B" : "#c2410c", fontSize: 11, margin: 0 }}>
                        <strong>Simulation active</strong> — 1M+ user record transfer Riyadh → Beijing.
                        Impacted: <strong>PIPL Art. 38–40</strong>, <strong>PDPL Art. 29</strong>, <strong>DSL Art. 31</strong>. Orange/red corridors require immediate remediation.
                    </p>
                </div>
            )}

            {/* ── Map Container ── */}
            <div ref={containerRef} style={{ position: "relative" }}>
                <style>{`
                    @keyframes djac-pipe-flow {
                        from { stroke-dashoffset: 40; }
                        to   { stroke-dashoffset: 0; }
                    }
                    @keyframes djac-node-ping {
                        0%, 100% { opacity: 0.2; transform: scale(1); }
                        50%      { opacity: 0.06; transform: scale(1.35); }
                    }
                    @keyframes djac-node-fast-ping {
                        0%, 100% { opacity: 0.35; transform: scale(1); }
                        50%      { opacity: 0.1;  transform: scale(1.5); }
                    }
                `}</style>

                <svg viewBox={`0 0 ${VB.w} ${VB.h}`} style={{ width: "100%", display: "block", maxHeight: 430 }}
                    onClick={() => { setSelectedPipe(null); setTooltip(null); }}>

                    {/* ── SVG Defs ── */}
                    <defs>
                        <filter id="sfh-glow-node" x="-60%" y="-60%" width="220%" height="220%">
                            <feGaussianBlur in="SourceGraphic" stdDeviation="2.5" result="b" />
                            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                        <filter id="sfh-glow-pipe" x="-30%" y="-100%" width="160%" height="300%">
                            <feGaussianBlur in="SourceGraphic" stdDeviation="3.5" result="b" />
                            <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                        {/* Per-pipe gradient along travel direction */}
                        {activePipes.map(pipe => {
                            const f = project(NODES[pipe.from].lon, NODES[pipe.from].lat);
                            const t2 = project(NODES[pipe.to].lon, NODES[pipe.to].lat);
                            const color = pipeColor(pipe.activeStatus, isDark);
                            return (
                                <linearGradient key={`lg-${pipe.id}`} id={`lg-${pipe.id}`}
                                    x1={f.x} y1={f.y} x2={t2.x} y2={t2.y} gradientUnits="userSpaceOnUse">
                                    <stop offset="0%" stopColor={color} stopOpacity="0.45" />
                                    <stop offset="50%" stopColor={color} stopOpacity="1.0" />
                                    <stop offset="100%" stopColor={color} stopOpacity="0.45" />
                                </linearGradient>
                            );
                        })}
                        <radialGradient id="sfh-ocean-glow" cx="45%" cy="78%" r="55%">
                            <stop offset="0%" stopColor={C.water} stopOpacity="0.5" />
                            <stop offset="100%" stopColor={C.water} stopOpacity="0" />
                        </radialGradient>
                    </defs>

                    {/* Background */}
                    <rect width={VB.w} height={VB.h} fill={C.bg} />

                    {/* Lat/lon grid */}
                    {[60, 120, 180, 240, 300, 360, 420].map(y => (
                        <line key={`gy${y}`} x1={0} y1={y} x2={VB.w} y2={y} stroke={C.grid} strokeWidth={0.4} />
                    ))}
                    {[80, 160, 240, 320, 400, 480, 560, 640, 720].map(x => (
                        <line key={`gx${x}`} x1={x} y1={0} x2={x} y2={VB.h} stroke={C.grid} strokeWidth={0.4} />
                    ))}

                    {/* ── Country shapes (real geographic outlines) ── */}
                    {COUNTRY_POLYS.map(c => (
                        <path key={c.id} d={pts2path(c.pts)}
                            fill={c.h ? C.landBright : C.land}
                            stroke={C.landEdge} strokeWidth={0.5} opacity={0.9} />
                    ))}
                    {COUNTRY_POLYS.filter(c => !!c.name && c.lx != null).map(c => {
                        const p = project(c.lx!, c.ly!);
                        return (
                            <text key={"lbl-" + c.id} x={p.x} y={p.y}
                                fill={C.muted} fontSize={5.5} textAnchor="middle"
                                opacity={0.5} style={{ pointerEvents: "none" } as React.CSSProperties}
                            >{c.name}</text>
                        );
                    })}

                    {/* ── Water bodies (painted on top) ── */}
                    <ellipse cx={195} cy={380} rx={145} ry={72} fill={C.water} opacity={0.7} />
                    <ellipse cx={425} cy={385} rx={108} ry={62} fill={C.water} opacity={0.68} />
                    <ellipse cx={615} cy={370} rx={105} ry={68} fill={C.water} opacity={0.68} />
                    <ellipse cx={160} cy={213} rx={35} ry={18} fill={C.water} opacity={0.82} />
                    <ellipse cx={20} cy={245} rx={18} ry={68} fill={C.water} opacity={0.80} />
                    <rect width={VB.w} height={VB.h} fill="url(#sfh-ocean-glow)" />

                    {/* ── Sea labels ── */}
                    <text x={70} y={292} fill={C.seaLabel} fontSize={8} fontWeight={700} textAnchor="middle" opacity={0.65} letterSpacing="0.12em">ARABIAN GULF</text>
                    <text x={190} y={418} fill={C.seaLabel} fontSize={8.5} fontWeight={700} textAnchor="middle" opacity={0.62} letterSpacing="0.09em">ARABIAN SEA</text>
                    <text x={418} y={428} fill={C.seaLabel} fontSize={8.5} fontWeight={700} textAnchor="middle" opacity={0.62} letterSpacing="0.09em">BAY OF BENGAL</text>
                    <text x={618} y={418} fill={C.seaLabel} fontSize={8.5} fontWeight={700} textAnchor="middle" opacity={0.62} letterSpacing="0.09em">SOUTH CHINA SEA</text>
                    <text x={22} y={220} fill={C.seaLabel} fontSize={6.5} fontWeight={700} textAnchor="middle" opacity={0.5} style={{ writingMode: "vertical-rl" } as React.CSSProperties}>RED SEA</text>

                    {/* ── Lat labels ── */}
                    {[[40, 103], [30, 181], [20, 260], [10, 338]].map(([deg, yv]) => (
                        <text key={deg} x={6} y={yv} fill={C.seaLabel} fontSize={6.5} opacity={0.45}>{deg}°N</text>
                    ))}

                    {/* ── Pipes ── */}
                    {filteredPipes.map(pipe => {
                        const f = project(NODES[pipe.from].lon, NODES[pipe.from].lat);
                        const t2 = project(NODES[pipe.to].lon, NODES[pipe.to].lat);
                        const d = cubicBez(f, t2);
                        const color = pipeColor(pipe.activeStatus, isDark);
                        const isHov = hoveredPipe === pipe.id;
                        const isSel = selectedPipe === pipe.id;
                        const speed = pipe.volume === "high" ? 2.4 : pipe.volume === "medium" ? 3.6 : 5.4;

                        return (
                            <g key={pipe.id}>
                                {(isHov || isSel) && (
                                    <path d={d} fill="none" stroke={color} strokeWidth={9}
                                        opacity={0.14} filter="url(#sfh-glow-pipe)" />
                                )}
                                {/* Shadow */}
                                <path d={d} fill="none" stroke={color} strokeWidth={5} opacity={0.09} />
                                {/* Main pipe — gradient + unique id for animateMotion mpath */}
                                <path id={`sfh-pipe-${pipe.id}`} d={d} fill="none"
                                    stroke={`url(#lg-${pipe.id})`}
                                    strokeWidth={isHov || isSel ? 2.8 : 1.9}
                                    strokeLinecap="round" />
                                {/* Animated dashes */}
                                <path d={d} fill="none" stroke={color}
                                    strokeWidth={isHov || isSel ? 2.8 : 1.9}
                                    strokeLinecap="round" strokeDasharray="7 15" opacity={0.82}
                                    style={{ animation: "djac-pipe-flow linear infinite", animationDuration: `${speed}s` }} />
                                {/* Data-packet dots — 3 staggered animateMotion */}
                                {([0, 0.36, 0.68] as const).map((offset, i) => (
                                    <circle key={i} r={pipe.volume === "high" ? 3 : 2.2}
                                        fill={color} opacity={0.92} filter="url(#sfh-glow-node)">
                                        <animateMotion
                                            dur={`${speed}s`}
                                            begin={`${-(offset * speed).toFixed(2)}s`}
                                            repeatCount="indefinite">
                                            <mpath href={`#sfh-pipe-${pipe.id}`} />
                                        </animateMotion>
                                    </circle>
                                ))}
                                {/* Hit area */}
                                <path d={d} fill="none" stroke="transparent" strokeWidth={20}
                                    style={{ cursor: "pointer" }}
                                    onMouseEnter={e => handlePipeMouse(e, pipe)}
                                    onMouseMove={e => handlePipeMouse(e, pipe)}
                                    onMouseLeave={e => handlePipeMouse(e, null)}
                                    onClick={e => handlePipeClick(e, pipe)} />
                            </g>
                        );
                    })}

                    {/* ── Nodes ── */}
                    {(Object.entries(NODES) as [NodeKey, typeof NODES[NodeKey]][]).map(([key, node]) => {
                        const { x, y } = project(node.lon, node.lat);
                        const score = calcScore(key, activePipes);
                        const sColor = scoreColor(score, isDark);
                        const arcPath = scoreArc(x, y, 13, score);
                        const hasViol = whatIfMode && activePipes.some(
                            p => (p.from === key || p.to === key) &&
                                (p.activeStatus === "simulated_violation" || p.activeStatus === "blocked"),
                        );
                        const accent = hasViol ? pipeColor("simulated_violation", isDark) : C.cyan;

                        return (
                            <g key={key}>
                                {/* Animated outer ping */}
                                <circle cx={x} cy={y} r={18} fill="none" stroke={accent} strokeWidth={1}
                                    style={{ animation: `${hasViol ? "djac-node-fast-ping" : "djac-node-ping"} ${hasViol ? 1.0 : 2.6}s ease-in-out infinite`, transformOrigin: `${x}px ${y}px` }} />
                                {/* Score ring track */}
                                <circle cx={x} cy={y} r={13} fill="none"
                                    stroke={isDark ? `${accent}18` : `${accent}14`} strokeWidth={3.5} />
                                {/* Score arc */}
                                <path d={arcPath} fill="none" stroke={sColor} strokeWidth={2.8} strokeLinecap="round" />
                                {/* Inner node */}
                                <circle cx={x} cy={y} r={8}
                                    fill={isDark ? "#0d1e3e" : "#ffffff"}
                                    stroke={accent} strokeWidth={hasViol ? 2.2 : 1.6}
                                    filter="url(#sfh-glow-node)" />
                                {/* Center dot */}
                                <circle cx={x} cy={y} r={3} fill={accent} opacity={0.9} />
                                {/* Score badge */}
                                <text x={x + 17} y={y - 8} fill={sColor} fontSize={7.5} fontWeight={900}>{score}%</text>
                                {/* City label */}
                                <text x={x} y={y + 24} fill={C.text} fontSize={9.5} fontWeight={700} textAnchor="middle">
                                    {node.code} {node.label}
                                </text>
                                {/* Jurisdiction */}
                                <text x={x} y={y + 34} fill={C.muted} fontSize={7} textAnchor="middle" opacity={0.85}>
                                    {node.jurisdiction}
                                </text>
                            </g>
                        );
                    })}

                    {/* ── Compass Rose ── */}
                    <CompassRose cx={712} cy={402} s={17} color={C.muted} />

                    {/* ── Scale Bar ── */}
                    <g opacity={0.5}>
                        <line x1={26} y1={418} x2={108} y2={418} stroke={C.muted} strokeWidth={1} />
                        <line x1={26} y1={414} x2={26} y2={422} stroke={C.muted} strokeWidth={1} />
                        <line x1={108} y1={414} x2={108} y2={422} stroke={C.muted} strokeWidth={1} />
                        <text x={67} y={430} fill={C.muted} fontSize={7} textAnchor="middle">≈ 2 000 km</text>
                    </g>
                </svg>

                {/* ── Glassmorphism HTML Tooltip ── */}
                {tooltip && containerRef.current && (() => {
                    const rect = containerRef.current.getBoundingClientRect();
                    const color = pipeColor(tooltip.pipe.activeStatus, isDark);
                    const TW = 224; const TH = 148;
                    let left = tooltip.clientX - rect.left + 16;
                    let top = tooltip.clientY - rect.top - 16;
                    if (left + TW > rect.width - 8) left = tooltip.clientX - rect.left - TW - 8;
                    if (top + TH > rect.height - 8) top = tooltip.clientY - rect.top - TH - 8;
                    return (
                        <div style={{
                            position: "absolute", left, top, pointerEvents: "none", zIndex: 20,
                            background: isDark ? "rgba(4,11,38,0.94)" : "rgba(235,243,255,0.96)",
                            backdropFilter: "blur(12px)",
                            border: `1px solid ${color}45`, borderTop: `2px solid ${color}`,
                            borderRadius: 10, padding: "10px 13px",
                            boxShadow: `0 6px 24px ${color}22, 0 2px 8px rgba(0,0,0,0.28)`,
                            minWidth: 190,
                        }}>
                            <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 7 }}>
                                <div style={{ color, flexShrink: 0 }}>{statusIcon(tooltip.pipe.activeStatus)}</div>
                                <span style={{ color: "var(--djac-text)", fontSize: 12, fontWeight: 800 }}>{tooltip.pipe.label}</span>
                            </div>
                            <div style={{ display: "flex", alignItems: "center", gap: 5, marginBottom: 6 }}>
                                <span style={{ width: 6, height: 6, borderRadius: "50%", background: color, display: "inline-block" }} />
                                <span style={{ color, fontSize: 10.5, fontWeight: 700 }}>{statusLabel(tooltip.pipe.activeStatus)}</span>
                            </div>
                            <div style={{ display: "flex", gap: 3, flexWrap: "wrap", marginBottom: 6 }}>
                                {tooltip.pipe.frameworks.map(fw => (
                                    <span key={fw} style={{ fontSize: 9, fontWeight: 800, color, background: `${color}14`, border: `1px solid ${color}38`, borderRadius: 4, padding: "1px 5px" }}>{fw}</span>
                                ))}
                                <span style={{ fontSize: 9, color: "var(--djac-muted)", alignSelf: "center", marginLeft: 2 }}>{tooltip.pipe.volume} vol</span>
                            </div>
                            {tooltip.pipe.articles && tooltip.pipe.articles.length > 0 && (
                                <div style={{ borderTop: `1px solid ${color}20`, paddingTop: 6 }}>
                                    <span style={{ fontSize: 8, color: "var(--djac-muted)", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.08em" }}>Required actions</span>
                                    {tooltip.pipe.articles.slice(0, 2).map((a, i) => (
                                        <p key={i} style={{ color: isDark ? "#FF9B6B" : "#c2410c", fontSize: 9.5, margin: i === 0 ? "3px 0 0" : "2px 0 0" }}>⚠ {a}</p>
                                    ))}
                                </div>
                            )}
                        </div>
                    );
                })()}
            </div>

            {/* ── Selected Pipe Panel ── */}
            {selectedPipe && (() => {
                const pipe = activePipes.find(p => p.id === selectedPipe)!;
                const color = pipeColor(pipe.activeStatus, isDark);
                const fromNode = NODES[pipe.from];
                const toNode = NODES[pipe.to];
                return (
                    <div style={{ borderTop: `1px solid ${color}40`, background: isDark ? `${color}07` : `${color}05`, padding: "12px 18px", display: "flex", alignItems: "flex-start", gap: 12 }}>
                        <div style={{ color, flexShrink: 0, marginTop: 2 }}>{statusIcon(pipe.activeStatus)}</div>
                        <div style={{ flex: 1, minWidth: 0 }}>
                            <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 5, flexWrap: "wrap" }}>
                                <span style={{ color: "var(--djac-text)", fontSize: 13, fontWeight: 800 }}>{pipe.label}</span>
                                <span style={{ color, fontSize: 11, fontWeight: 600 }}>— {statusLabel(pipe.activeStatus)}</span>
                                <span style={{ color: "var(--djac-muted)", fontSize: 10 }}>
                                    {fromNode.code} {fromNode.label} → {toNode.code} {toNode.label}
                                </span>
                            </div>
                            <div style={{ display: "flex", gap: 5, flexWrap: "wrap", marginBottom: pipe.articles ? 7 : 0 }}>
                                {pipe.frameworks.map(fw => (
                                    <Badge key={fw} variant="outline" style={{ fontSize: 10, height: 18, borderColor: `${color}50`, color }}>{fw}</Badge>
                                ))}
                                <Badge variant="outline" style={{ fontSize: 10, height: 18, borderColor: "var(--djac-border)", color: "var(--djac-muted)" }}>{pipe.volume} volume</Badge>
                            </div>
                            {pipe.articles && (
                                <p style={{ color: isDark ? "#FF9B6B" : "#c2410c", fontSize: 11, margin: 0 }}>
                                    <strong>Required actions:</strong> {pipe.articles.join("  ·  ")}
                                </p>
                            )}
                        </div>
                        <button type="button" onClick={() => setSelectedPipe(null)}
                            style={{ color: "var(--djac-muted)", background: "none", border: "none", cursor: "pointer", padding: 2, flexShrink: 0 }}
                            aria-label="Close"><X className="h-3.5 w-3.5" /></button>
                    </div>
                );
            })()}

            {/* ── Footer ── */}
            <div style={{ padding: "7px 18px", borderTop: "1px solid var(--djac-border)", display: "flex", alignItems: "center", gap: 6 }}>
                <Info style={{ color: "var(--djac-muted)", width: 11, height: 11, flexShrink: 0 }} />
                <p style={{ color: "var(--djac-muted)", fontSize: 9.5, margin: 0 }}>
                    {t("heatmap.sinoGulf.hint", "Hover corridor for details · Click to pin · Filter by framework · What-If simulates 1M+ record transfer")}
                </p>
            </div>
        </div>
    );
}
