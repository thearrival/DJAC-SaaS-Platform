# ────────────────────────────────────────────────────────────────────────────
# DJAC SaaS — Environment Configuration
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development. All values have safe defaults.
# Production startup guards (in server/_core/env.ts) will check for required
# variables and refuse to start if critical ones are missing.
# ────────────────────────────────────────────────────────────────────────────


# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
VITE_APP_ID=DJAC
JWT_SECRET=djac-dev-local-only-not-for-production-use-set-jwt-secret

# Cookie domain (set to .your-domain.com for production)
COOKIE_DOMAIN=


# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Get your connection string from Supabase Dashboard → Project Settings → Database
# Falls back through: DATABASE_URL → POSTGRES_URL → POSTGRES_URL_NON_POOLING → POSTGRES_PRISMA_URL
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
DATABASE_POOL_SIZE=5          # 25 recommended for production


# ─── Supabase (Auth / Realtime / Storage) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─── Stripe Billing ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create prices in your Stripe dashboard and configure here:
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_QUARTERLY=
STRIPE_PRICE_STARTER_BIANNUAL=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_QUARTERLY=
STRIPE_PRICE_PRO_BIANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_ANNUAL=


# ─── Redis (BullMQ AI Queue) ────────────────────────────────────────────────
REDIS_URL=
AI_QUEUE_MODE=in_memory       # in_memory | redis — auto-selected in production if REDIS_URL is set
AI_ORCHESTRATOR_ENABLED=true
AI_JOB_TIMEOUT_MS=45000
AI_VALIDATOR_MAX_RETRIES=1
AI_RAG_TOP_K=12
AI_JOB_HISTORY_FILE=
AI_WEBSOCKET_PATH=/ws/ai-jobs
AGENT_SWARM_BASE_URL=


# ─── OpenAI (AI Reports & Analysis) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o


# ─── SMTP (Email — OTP, Trial Reminders, Report Delivery) ───────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=


# ─── Auth — OAuth (Google / GitHub) ─────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/oauth/callback


# ─── Auth — Dev Bypass (development only) ───────────────────────────────────
DEV_AUTH_BYPASS=false
DEV_AUTH_OPEN_ID=local-dev-user
DEV_AUTH_NAME=Local Developer
DEV_AUTH_EMAIL=
DEV_AUTH_ROLE=user


# ─── Sentry Error Tracking ──────────────────────────────────────────────────
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=development


# ─── File Uploads (S3-compatible) ───────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=


# ─── Yalla Admin Internal Portal ────────────────────────────────────────────
YALLA_ADMIN_SECRET=
YALLA_ADMIN_USERNAME=yalla_admin
YALLA_ADMIN_PASSWORD=          # bcrypt hash of the admin password
YALLA_ADMIN_IP_ALLOWLIST=      # comma-separated IPs or CIDR ranges
YALLA_ADMIN_JWT_SECRET=
YALLA_ADMIN_SESSION_TTL_HOURS=8


# ─── Reporting ──────────────────────────────────────────────────────────────
REPORT_TEMPLATE_NAME=Yalla Hack Official Report Template
REPORT_NATIVE_PDF_CONVERSION=true


# ─── Interaction Retention ──────────────────────────────────────────────────
INTERACTION_RETENTION_AUTORUN=true
INTERACTION_RETENTION_DAYS=90
INTERACTION_RETENTION_INTERVAL_HOURS=24


# ─── HTTP Timeouts ──────────────────────────────────────────────────────────
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=120000


# ─── Compliance Cache ───────────────────────────────────────────────────────
COMPLIANCE_CACHE_TTL_MS=10000    # 60s recommended for production


# ─── Feature Flags ──────────────────────────────────────────────────────────
ALLOW_IN_MEMORY_PERSISTENCE=true   # set false in production
ENABLE_MANUS_RUNTIME=false
ENABLE_JSX_LOC=false


# ─── Forge API (Built-in Integration) ───────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
