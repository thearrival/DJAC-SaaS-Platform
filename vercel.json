{
  "version": 2,
  "buildCommand": "vite build && node scripts/prebuild-vercel.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "functions": {
    "api/[[...path]].js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ping.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
