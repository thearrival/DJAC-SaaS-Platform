{
  "version": 2,
  "buildCommand": "NODE_TLS_REJECT_UNAUTHORIZED=0 vite build && NODE_TLS_REJECT_UNAUTHORIZED=0 node scripts/prebuild-vercel.mjs && NODE_TLS_REJECT_UNAUTHORIZED=0 npx drizzle-kit migrate",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "functions": {
    "api/index.mjs": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ping.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/ping",
      "dest": "/api/ping"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index?api_path=$1"
    },
    {
      "src": "/((?!api/|assets/|\\.well-known/)[^.]*)$",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
