{
  "version": 2,
  "buildCommand": "node scripts/prebuild-vercel.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60
    },
    "api/ping.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/ping",
      "dest": "/api/ping"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index?api_path=$1"
    },
    {
      "src": "/assets/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/((?!api/|assets/|\\.well-known/)[^.]*)$",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
