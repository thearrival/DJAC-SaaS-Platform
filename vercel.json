{
  "version": 2,
  "buildCommand": "vite build && node scripts/prebuild-vercel.mjs",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index?api_path=$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
