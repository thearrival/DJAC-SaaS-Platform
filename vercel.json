{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "functions": {
    "api/[[...path]].ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/ping.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production",
    "VITE_API_URL": "/api"
  }
}
