# ─────────────────────────────────────────────────────────────────────────────
# DJAC Tool — Production Environment Variable Template
#
# Copy this file to /docker/djac/.env.production on the VPS and fill in all
# values marked [REQUIRED]. Never commit the actual .env.production file.
#
# On the VPS set permissions:  chmod 600 /docker/djac/.env.production
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# [REQUIRED] Full public URL (no trailing slash, must match OAuth callback base)
APP_URL=https://app.yalla-hack.ae

# [REQUIRED] For Traefik routing — just the hostname
APP_DOMAIN=app.yalla-hack.ae
BASE_DOMAIN=yalla-hack.ae

# ── Security ─────────────────────────────────────────────────────────────────
# [REQUIRED] JWT/cookie signing secret — minimum 64 random characters
# Generate:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] MariaDB root password (for administrative operations only)
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# [REQUIRED] Application DB user password
MYSQL_PASSWORD=REPLACE_WITH_STRONG_APP_PASSWORD

# DATABASE_URL is constructed automatically by docker-compose from MYSQL_PASSWORD:
#   mysql://djac:${MYSQL_PASSWORD}@db:3306/djac_tool
# If you run migrations outside Docker, set this manually:
# DATABASE_URL=mysql://djac:REPLACE_WITH_STRONG_APP_PASSWORD@127.0.0.1:3306/djac_tool

# ── Redis ────────────────────────────────────────────────────────────────────
# [REQUIRED] Redis password — enforced via requirepass in redis container
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD

# REDIS_URL is constructed in docker-compose as redis://:${REDIS_PASSWORD}@redis:6379
# If you need to override it:
# REDIS_URL=redis://:REPLACE_WITH_STRONG_REDIS_PASSWORD@redis:6379

# ── AI / Queue ───────────────────────────────────────────────────────────────
# "redis" for distributed BullMQ mode (required in production)
AI_QUEUE_MODE=redis

# [REQUIRED for AI features] OpenAI-compatible API key
OPENAI_API_KEY=sk-...

# Optional: external agent swarm base URL
AGENT_SWARM_BASE_URL=

# AI orchestrator toggles
AI_ORCHESTRATOR_ENABLED=true
AI_VALIDATOR_MAX_RETRIES=2
AI_JOB_TIMEOUT_MS=120000
AI_WEBSOCKET_PATH=/ws/ai-jobs

# Number of top-k documents returned from RAG search (default: 12)
AI_RAG_TOP_K=12

# ─── Yalla-Admin Owner Console ─────────────────────────────────────────────────
# [REQUIRED] Long random secret — used to sign owner access links and gate the console
YALLA_ADMIN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# [REQUIRED] Owner console login credentials
YALLA_ADMIN_USERNAME=yalla_admin
# bcrypt hash — generate with: node -e "require('bcrypt').hash('yourpassword',12).then(console.log)"
YALLA_ADMIN_PASSWORD=REPLACE_WITH_BCRYPT_HASH

# [OPTIONAL] Separate JWT secret for admin sessions (defaults to JWT_SECRET)
YALLA_ADMIN_JWT_SECRET=

# [OPTIONAL] Comma-separated IP allowlist — leave empty to allow all IPs
YALLA_ADMIN_IP_ALLOWLIST=

# Session TTL in hours (default: 8)
YALLA_ADMIN_SESSION_TTL_HOURS=8

# ── Manus / Platform OAuth ────────────────────────────────────────────────────
# Platform OAuth server URL — the Manus auth server
OAUTH_SERVER_URL=https://auth.manus.im

# [REQUIRED if using OAuth] Vite app ID registered in the OAuth provider
VITE_APP_ID=REPLACE_WITH_MANUS_APP_ID

# [REQUIRED if using OAuth] Owner's open ID for platform-level admin bootstrap
OWNER_OPEN_ID=REPLACE_WITH_OWNER_OPEN_ID

# Forge API (Manus internal infra)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=REPLACE_WITH_FORGE_API_KEY

# ── Stripe / Billing (optional — app boots without these) ────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_QUARTERLY=price_...
STRIPE_PRICE_STARTER_BIANNUAL=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_QUARTERLY=price_...
STRIPE_PRICE_PRO_BIANNUAL=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_...

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=djac@yourdomain.com
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM="DJAC Tool <djac@yourdomain.com>"

# ── Observability ────────────────────────────────────────────────────────────
# Sentry DSN for error tracking (https://sentry.io)
SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ── Storage ──────────────────────────────────────────────────────────────────
# Optional: AWS S3 / Cloudflare R2 for report file storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_S3_BUCKET=

# ── In-Memory Persistence Guard ──────────────────────────────────────────────
# [REQUIRED] Must be "false" in production to enforce DB persistence
ALLOW_IN_MEMORY_PERSISTENCE=false

# ── Database Pool ────────────────────────────────────────────────────────────
# Max simultaneous DB connections (default: 25 in production)
DATABASE_POOL_SIZE=25

# ── Compliance Cache ─────────────────────────────────────────────────────────
# Framework data cache TTL in milliseconds (default: 60000 = 60s in production)
COMPLIANCE_CACHE_TTL_MS=60000

# ── Interaction Log Retention ─────────────────────────────────────────────────
# Auto-purge user interaction logs older than N days (GDPR right-to-erasure)
INTERACTION_RETENTION_AUTORUN=true
INTERACTION_RETENTION_DAYS=90
INTERACTION_RETENTION_INTERVAL_HOURS=24

# ── HTTP Tuning ──────────────────────────────────────────────────────────────
# Keep-alive timeout in ms — should exceed load balancer idle timeout (default: 65000)
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000

# ── Reports ──────────────────────────────────────────────────────────────────
# Label shown in generated PDF/Word report headers
REPORT_TEMPLATE_NAME=Yalla Hack Official Report Template

# ── Development Overrides (MUST NOT be set in production) ────────────────────
# DEV_AUTH_BYPASS=false
# DEV_AUTH_OPEN_ID=
# DEV_AUTH_NAME=
# DEV_AUTH_EMAIL=
# DEV_AUTH_ROLE=
